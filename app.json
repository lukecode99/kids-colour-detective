        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-camera"
    ],
    "extra": {
      "eas": {
        "projectId": "aa06313f-dc9d-4ec9-a724-c885adf4f1e3"
      }
    },
    "owner": "nanoluke",
    "web": {
      "backgroundColor": "#0D0E1A",
      "themeColor": "#0D0E1A"
    }
  }
